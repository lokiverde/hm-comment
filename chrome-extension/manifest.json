{
  "manifest_version": 3,
  "name": "HM Comment",
  "version": "2.1",
  "description": "AI-powered LinkedIn comment generator using n8n and OpenRouter",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HM Comment Settings"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["contentscript.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
